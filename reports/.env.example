# BLAST Summary Tool - AI API配置示例
# 支持多端点配置，当主端点失败时自动切换到备用端点

#####################
# 主API配置（索引0）
OPENAI_API_KEY_0=your-primary-api-key
OPENAI_BASE_URL_0=https://api.openai.com/v1
OPENAI_MODEL_0=gpt-4

# 备用API配置（索引1）- 可选
# OPENAI_API_KEY_1=your-backup-api-key
# OPENAI_BASE_URL_1=https://api.deepseek.com/v1
# OPENAI_MODEL_1=deepseek-chat

# 更多备用端点（索引2, 3, ...）- 可选
# OPENAI_API_KEY_2=your-third-api-key
# OPENAI_BASE_URL_2=https://api.anthropic.com/v1
# OPENAI_MODEL_2=claude-3

#####################
# 通用参数
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7
OPENAI_RETRY_COUNT=1           # 每个API端点的重试次数
OPENAI_FAILOVER_ENABLED=true   # 是否启用故障转移

#####################
# 向后兼容格式（不推荐使用）
# 如果不使用索引式配置，也可以使用旧格式：
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4
